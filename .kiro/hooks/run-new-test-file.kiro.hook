{
  "enabled": true,
  "name": "Run New Test File",
  "description": "Khi có file test mới được tạo, nhắc agent chạy test đó và kiểm tra kết quả",
  "version": "1",
  "when": {
    "type": "fileCreated",
    "patterns": [
      "src/**/*.test.ts"
    ]
  },
  "then": {
    "type": "askAgent",
    "prompt": "Một file test mới vừa được tạo. Hãy chạy `npx vitest run` để kiểm tra kết quả. Nếu test fail, phân tích lỗi và fix ngay."
  }
}