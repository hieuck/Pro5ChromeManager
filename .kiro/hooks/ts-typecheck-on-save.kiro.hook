{
  "enabled": true,
  "name": "TypeScript Type Check on Save",
  "description": "Chạy tsc --noEmit sau khi lưu file TypeScript để phát hiện type errors ngay lập tức",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "src/**/*.ts",
      "src/**/*.tsx"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "npx tsc --noEmit",
    "timeout": 60
  },
  "workspaceFolderName": "Pro5ChromeManager",
  "shortName": "ts-typecheck-on-save"
}