{
  "server": {
    "host": "127.0.0.1",
    "port": 3210,
    "cors": true
  },
  "database": {
    "type": "sqlite",
    "connectionString": "./data/app.db"
  },
  "features": {
    "fingerprinting": true,
    "proxyManagement": true,
    "extensionManagement": true,
    "backup": {
      "enabled": true,
      "intervalHours": 24,
      "retentionDays": 7
    }
  },
  "monitoring": {
    "enabled": true,
    "logLevel": "info"
  },
  "paths": {
    "dataDir": "./data",
    "profilesDir": "./data/profiles",
    "logsDir": "./data/logs",
    "backupsDir": "./data/backups"
  },
  "security": {}
}