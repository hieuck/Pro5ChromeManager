{
  "name": "pro5-chrome-manager",
  "version": "1.0.0",
  "description": "Pro5 Chrome Manager desktop app for isolated Chromium profiles",
  "main": "dist/electron-main/main.js",
  "scripts": {
    "build:server": "tsc -p tsconfig.json",
    "build:ui": "node -r ./scripts/vite-safe-realpath-shim.cjs ./node_modules/vite/bin/vite.js build --configLoader runner",
    "build:ui:optimized": "node -r ./scripts/vite-safe-realpath-shim.cjs ./node_modules/vite/bin/vite.js build --config vite.config.optimized.mjs",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build": "npm run build:server && npm run build:ui && npm run build:electron",
    "build:optimized": "npm run build:server && npm run build:ui:optimized && npm run build:electron",
    "analyze:bundle": "npm run build:ui:optimized && start dist/stats.html",
    "ops:verify:dev-package": "node scripts/verify-dev-package.js",
    "ops:smoke:dev-package": "node scripts/dev-package-smoke.js",
    "ops:artifacts": "node scripts/release-artifacts.js",
    "ops:artifacts:verify": "node scripts/release-artifacts.js --verify",
    "ops:preflight": "node scripts/release-preflight.js",
    "ops:preflight:built": "node scripts/release-preflight.js --built",
    "ops:smoke": "node scripts/ops-smoke.js",
    "browser-fork:doctor": "node scripts/browser-fork/doctor.js",
    "browser-fork:bootstrap": "node scripts/browser-fork/bootstrap-windows.js",
    "browser-fork:gn": "node scripts/browser-fork/generate-gn.js",
    "browser-core:package": "node scripts/package-browser-core.js",
    "release:preflight": "node scripts/release-preflight.js --strict --built",
    "start": "node dist/server/server/index.js",
    "launch:desktop": "node scripts/launch-desktop.js",
    "dev:server": "ts-node-dev --respawn --transpile-only src/server/index.ts",
    "dev:ui": "vite",
    "dev:electron": "npm run build && node scripts/run-electron-local.js",
    "ops:smoke:local": "npm run build && node scripts/local-app-smoke.js",
    "package:electron:dev": "npm run generate:icons && npm run build && electron-builder --dir --win --config electron-builder.yml --config.win.signAndEditExecutable=false && npm run ops:verify:dev-package && npm run ops:smoke:dev-package",
    "generate:icons": "node scripts/generate-icons.js",
    "package:electron": "npm run generate:icons && npm run build && electron-builder --config electron-builder.yml && npm run ops:artifacts && npm run ops:artifacts:verify",
    "test": "node -r ./scripts/vite-safe-realpath-shim.cjs ./node_modules/vitest/vitest.mjs run --configLoader runner",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report"
  },
  "keywords": [
    "anti-detect",
    "browser",
    "profile",
    "manager"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@ant-design/icons": "^5.3.7",
    "antd": "^5.18.3",
    "archiver": "^7.0.1",
    "compression": "^1.8.1",
    "electron-updater": "^6.8.3",
    "express": "^4.19.2",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "proxy-chain": "^2.4.0",
    "react-router-dom": "^6.24.0",
    "uuid": "^10.0.0",
    "winston": "^3.13.0",
    "winston-daily-rotate-file": "^5.0.0",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/archiver": "^6.0.2",
    "@types/compression": "^1.7.5",
    "@types/express": "^4.17.21",
    "@types/helmet": "^4.0.0",
    "@types/lru-cache": "^7.10.10",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.10",
    "@vitejs/plugin-react": "^4.7.0",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "lru-cache": "^10.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "rollup-plugin-visualizer": "^5.12.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5",
    "vite": "^6.4.1",
    "vitest": "^3.2.4"
  }
}
