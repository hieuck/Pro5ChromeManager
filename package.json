{
  "name": "anti-detect-browser-manager",
  "version": "1.0.0",
  "description": "Anti-Detect Browser Manager - quản lý trình duyệt đa profile",
  "main": "dist/electron-main/main.js",
  "scripts": {
    "build:server": "tsc -p tsconfig.json",
    "build:ui": "vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build": "npm run build:server && npm run build:ui && npm run build:electron",
    "ops:verify:dev-package": "node scripts/verify-dev-package.js",
    "ops:artifacts": "node scripts/release-artifacts.js",
    "ops:artifacts:verify": "node scripts/release-artifacts.js --verify",
    "ops:preflight": "node scripts/release-preflight.js",
    "ops:preflight:built": "node scripts/release-preflight.js --built",
    "ops:smoke": "node scripts/ops-smoke.js",
    "release:preflight": "node scripts/release-preflight.js --strict --built",
    "start": "node dist/server/index.js",
    "dev:server": "ts-node-dev --respawn --transpile-only src/server/index.ts",
    "dev:ui": "vite",
    "dev:electron": "npm run build && node scripts/run-electron-local.js",
    "ops:smoke:local": "npm run build && node scripts/local-app-smoke.js",
    "package:electron:dev": "npm run generate:icons && npm run build && electron-builder --dir --win --config electron-builder.yml --config.win.signAndEditExecutable=false && npm run ops:verify:dev-package",
    "generate:icons": "node scripts/generate-icons.js",
    "package:electron": "npm run generate:icons && npm run build && electron-builder --config electron-builder.yml && npm run ops:artifacts && npm run ops:artifacts:verify",
    "test": "vitest run"
  },
  "keywords": [
    "anti-detect",
    "browser",
    "profile",
    "manager"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@ant-design/icons": "^5.3.7",
    "antd": "^5.18.3",
    "archiver": "^7.0.1",
    "electron-updater": "^6.8.3",
    "express": "^4.19.2",
    "proxy-chain": "^2.4.0",
    "react-router-dom": "^6.24.0",
    "uuid": "^10.0.0",
    "winston": "^3.13.0",
    "winston-daily-rotate-file": "^5.0.0",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/archiver": "^6.0.2",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.10",
    "@vitejs/plugin-react": "^4.7.0",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5",
    "vite": "^6.4.1",
    "vitest": "^3.2.4"
  }
}
