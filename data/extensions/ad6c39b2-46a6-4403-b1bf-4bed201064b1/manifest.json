{
  "manifest_version": 3,
  "name": "Fingerprint Injector",
  "version": "1.0.0",
  "description": "Injects fingerprint overrides into page context",
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content_script.js"
      ],
      "run_at": "document_start",
      "all_frames": true,
      "world": "MAIN"
    }
  ]
}